# Primary key (required)
GOOGLE_GENERATIVE_AI_API_KEY=your_key_1

# Fallback keys when one hits quota (optional, numbered 2–50)
GEMINI_API_KEY_2=your_key_2
GEMINI_API_KEY_3=your_key_3
# GEMINI_API_KEY_4=...
# GEMINI_API_KEY_10=...

# Or all keys comma-separated in one line:
# GOOGLE_GENERATIVE_AI_API_KEYS=key1,key2,key3

# Model: gemini-2.5-flash, gemini-2.0-flash-lite, gemini-1.5-flash
GEMINI_MODEL=gemini-2.5-flash
